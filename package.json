{
  "name": "cardon",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "apps/web",
    "apps/partner",
    "apps/admin",
    "packages/build-info",
    "packages/cms-typography"
  ],
  "description": "CardOn.vn — Digital Product Distribution Platform",
  "scripts": {
    "build": "nest build",
    "build:web": "npm run build --workspace=@cardon/web",
    "build:partner": "npm run build --workspace=@cardon/partner",
    "build:admin": "npm run build --workspace=@cardon/admin",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "start:worker": "node dist/worker",
    "test": "jest",
    "test:auth": "jest --testPathPattern=\"(auth|permission-cache)\"",
    "test:product": "jest --testPathPattern=product",
    "test:order": "jest --testPathPattern=order",
    "test:payment": "jest --testPathPattern=payment",
    "test:provider": "jest --testPathPattern=provider",
    "test:agent": "jest --testPathPattern=agent",
    "test:agent-api": "jest --testPathPattern=agent-api",
    "test:admin": "jest --testPathPattern=admin",
    "test:finance": "jest --testPathPattern=finance",
    "test:notification": "jest --testPathPattern=notification",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:manual": "powershell -ExecutionPolicy Bypass -File scripts/apply-manual.ps1",
    "prisma:validate": "prisma validate",
    "prisma:format": "prisma format",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "prisma db seed",
    "prisma:status": "prisma migrate status",
    "prisma:generate": "prisma generate",
    "reset:local-admin": "node --experimental-strip-types scripts/reset-local-admin.ts"
  },
  "prisma": {
    "seed": "node prisma/seed.mjs"
  },
  "dependencies": {
    "@nestjs/bullmq": "^11.0.2",
    "@nestjs/common": "^11.0.12",
    "@nestjs/config": "^4.0.1",
    "@nestjs/core": "^11.0.12",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.12",
    "@nestjs/throttler": "^6.4.0",
    "@prisma/client": "^6.9.0",
    "bcryptjs": "^3.0.2",
    "bullmq": "^5.44.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "exceljs": "^4.4.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.6.0",
    "joi": "^17.13.3",
    "nodemailer": "^6.10.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.6",
    "@nestjs/schematics": "^11.0.5",
    "@nestjs/testing": "^11.0.12",
    "@types/express": "^5.0.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.10",
    "@types/nodemailer": "^6.4.24",
    "@types/passport-jwt": "^4.0.1",
    "jest": "^29.7.0",
    "prisma": "^6.9.0",
    "ts-jest": "^29.2.6",
    "typescript": "^5.8.2"
  }
}

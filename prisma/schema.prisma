// =============================================================================
// AUTH
// =============================================================================

model User {
  id                 String     @id @default(uuid()) @db.Uuid
  username           String?    @unique @db.VarChar(32)
  fullName           String?    @map("full_name") @db.VarChar(128)
  email              String     @unique @db.VarChar(255)
  phone              String?    @db.VarChar(32)
  identityNumberEnc  String?    @map("identity_number_enc") @db.VarChar(512)
  passwordHash       String     @map("password_hash") @db.VarChar(255)
  role               UserRole
  status             UserStatus @default(ACTIVE)
  emailVerifiedAt    DateTime?  @map("email_verified_at") @db.Timestamptz(6)
  acceptedTermsAt    DateTime?  @map("accepted_terms_at") @db.Timestamptz(6)
  lastLoginAt        DateTime?  @map("last_login_at") @db.Timestamptz(6)
  createdAt          DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt          DateTime?  @map("deleted_at") @db.Timestamptz(6)

  agent                   Agent?
  agentMembers            AgentMember[]
  agentMembersInvited     AgentMember[] @relation("AgentMemberInvitedBy")
  agentLoginHistories     AgentLoginHistory[]
  agentInvitesSent        AgentMemberInvite[] @relation("AgentMemberInviteInviter")
  impersonationsStarted   AgentImpersonationSession[] @relation("ImpersonationAdmin")
  impersonationsTarget    AgentImpersonationSession[] @relation("ImpersonationTarget")
  orders                  Order[]
  invoices                Invoice[]
  passwordResetTokens     PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  refreshTokens           RefreshToken[]
  ledgerEntriesCreated    LedgerEntry[]            @relation("LedgerCreatedBy")
  agentKycReviews         AgentKyc[]               @relation("KycReviewer")
  auditLogs               AuditLog[]
  cmsPages                CmsPage[]
  agentInvitesCreated     AgentInvite[] @relation("AgentInviteCreator")
  agentInviteUsed         AgentInvite?  @relation("AgentInviteUsedBy")
  supportTickets          SupportTicket[] @relation("SupportTicketCustomer")
  cardAccessLogs          CardAccessLog[]

  @@index([deletedAt])
  @@map("users")
}

model Permission {
  id          String   @id @default(uuid()) @db.Uuid
  code        String   @unique @db.VarChar(64)
  description String?  @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  rolePermissions RolePermission[]

  @@index([code])
  @@map("permissions")
}

model RolePermission {
  id           String   @id @default(uuid()) @db.Uuid
  role         UserRole
  permissionId String   @map("permission_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([role, permissionId])
  @@index([role])
  @@map("role_permissions")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @map("token_hash") @db.VarChar(255)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @map("token_hash") @db.VarChar(255)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  usedAt    DateTime? @map("used_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

model EmailVerificationToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @map("token_hash") @db.VarChar(255)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  usedAt    DateTime? @map("used_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("email_verification_tokens")
}

// =============================================================================
// AGENT
// =============================================================================

model Agent {
  id                   String      @id @default(uuid()) @db.Uuid
  userId               String      @unique @map("user_id") @db.Uuid
  companyName          String      @map("company_name") @db.VarChar(255)
  balance              Decimal     @default(0) @db.Decimal(18, 2)
  heldBalance          Decimal     @default(0) @map("held_balance") @db.Decimal(18, 2)
  apiKeyHash           String?     @map("api_key_hash") @db.VarChar(255)
  apiKeyLookup         String?     @unique @map("api_key_lookup") @db.VarChar(64)
  secretKeyEncrypted   String?     @map("secret_key_encrypted") @db.Text
  lastUsedAt           DateTime?   @map("last_used_at") @db.Timestamptz(6)
  contactEmail         String?     @map("contact_email") @db.VarChar(255)
  rateLimit            Int         @default(100) @map("rate_limit")
  apiEnabled           Boolean     @default(false) @map("api_enabled")
  securityConfig       Json        @default("{}") @map("security_config")
  status               AgentStatus @default(PENDING_KYC)
  createdAt            DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt            DateTime?   @map("deleted_at") @db.Timestamptz(6)

  user                User                 @relation(fields: [userId], references: [id], onDelete: Restrict)
  kyc                 AgentKyc?
  webhookConfig       AgentWebhookConfig?
  productPrices       AgentProductPrice[]
  financialTransactions FinancialTransaction[]
  orders              Order[]
  ledgerEntries       LedgerEntry[]
  invoices            Invoice[]
  deposits            AgentDeposit[]
  manualCredits         AgentManualCredit[]
  agentStatements     AgentStatement[]
  statementAdjustments AgentStatementAdjustment[]
  apiRequestLogs      AgentApiRequestLog[]
  members             AgentMember[]
  memberInvites       AgentMemberInvite[]
  impersonationSessions AgentImpersonationSession[]

  @@index([deletedAt])
  @@map("agents")
}

model AgentMember {
  id               String            @id @default(uuid()) @db.Uuid
  agentId          String            @map("agent_id") @db.Uuid
  userId           String            @unique @map("user_id") @db.Uuid
  role             AgentMemberRole   @default(OPERATOR)
  status           AgentMemberStatus @default(ACTIVE)
  displayName      String?           @map("display_name") @db.VarChar(128)
  twoFactorEnabled Boolean           @default(false) @map("two_factor_enabled")
  invitedById      String?           @map("invited_by_id") @db.Uuid
  lastLoginAt      DateTime?         @map("last_login_at") @db.Timestamptz(6)
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)

  agent     Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  user      User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  invitedBy User? @relation("AgentMemberInvitedBy", fields: [invitedById], references: [id], onDelete: SetNull)

  @@unique([agentId, userId])
  @@index([agentId])
  @@index([status])
  @@map("agent_members")
}

model AgentMemberInvite {
  id           String                  @id @default(uuid()) @db.Uuid
  agentId      String                  @map("agent_id") @db.Uuid
  email        String                  @db.VarChar(255)
  role         AgentMemberRole
  tokenHash    String                  @map("token_hash") @db.VarChar(255)
  status       AgentMemberInviteStatus @default(PENDING)
  expiresAt    DateTime                @map("expires_at") @db.Timestamptz(6)
  invitedById  String                  @map("invited_by_id") @db.Uuid
  acceptedAt   DateTime?               @map("accepted_at") @db.Timestamptz(6)
  createdAt    DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime                @updatedAt @map("updated_at") @db.Timestamptz(6)

  agent     Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  invitedBy User  @relation("AgentMemberInviteInviter", fields: [invitedById], references: [id], onDelete: Restrict)

  @@index([agentId])
  @@index([email])
  @@index([tokenHash])
  @@index([status])
  @@map("agent_member_invites")
}

model AgentLoginHistory {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  agentId   String?  @map("agent_id") @db.Uuid
  ipAddress String?  @map("ip_address") @db.VarChar(64)
  country   String?  @db.VarChar(64)
  userAgent String?  @map("user_agent") @db.VarChar(512)
  browser   String?  @db.VarChar(128)
  device    String?  @db.VarChar(128)
  result    String   @db.VarChar(32)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([agentId])
  @@map("agent_login_histories")
}

model AgentImpersonationSession {
  id           String    @id @default(uuid()) @db.Uuid
  adminUserId  String    @map("admin_user_id") @db.Uuid
  targetUserId String    @map("target_user_id") @db.Uuid
  agentId      String    @map("agent_id") @db.Uuid
  readOnly     Boolean   @default(true) @map("read_only")
  ipAddress    String?   @map("ip_address") @db.VarChar(64)
  startedAt    DateTime  @default(now()) @map("started_at") @db.Timestamptz(6)
  endedAt      DateTime? @map("ended_at") @db.Timestamptz(6)

  adminUser  User  @relation("ImpersonationAdmin", fields: [adminUserId], references: [id], onDelete: Cascade)
  targetUser User  @relation("ImpersonationTarget", fields: [targetUserId], references: [id], onDelete: Cascade)
  agent      Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([adminUserId])
  @@index([agentId])
  @@index([targetUserId])
  @@map("agent_impersonation_sessions")
}

model AgentApiRequestLog {
  id              String   @id @default(uuid()) @db.Uuid
  agentId         String   @map("agent_id") @db.Uuid
  requestTime     DateTime @default(now()) @map("request_time") @db.Timestamptz(6)
  requestId       String?  @map("request_id") @db.VarChar(128)
  apiKeyMasked    String?  @map("api_key_masked") @db.VarChar(64)
  sourceIp        String?  @map("source_ip") @db.VarChar(64)
  endpoint        String   @db.VarChar(512)
  method          String   @db.VarChar(16)
  httpStatus      Int      @map("http_status")
  latencyMs       Int?     @map("latency_ms")
  gateway         String?  @default("partner_api") @db.VarChar(64)
  provider        String?  @db.VarChar(64)
  orderId         String?  @map("order_id") @db.Uuid
  partnerOrderId  String?  @map("partner_order_id") @db.VarChar(128)
  responseCode    String?  @map("response_code") @db.VarChar(64)
  responseMessage String?  @map("response_message") @db.VarChar(512)
  errorCode       String?  @map("error_code") @db.VarChar(64)
  errorMessage    String?  @map("error_message") @db.VarChar(512)
  logType         String   @map("log_type") @db.VarChar(32)
  retry           Boolean  @default(false)
  userAgent       String?  @map("user_agent") @db.VarChar(512)
  correlationId   String?  @map("correlation_id") @db.VarChar(128)
  requestHeaders  Json     @default("{}") @map("request_headers")
  requestBody     Json?    @map("request_body")
  responseBody    Json?    @map("response_body")
  responseHeaders Json     @default("{}") @map("response_headers")

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId, requestTime])
  @@index([requestId])
  @@index([orderId])
  @@index([partnerOrderId])
  @@index([endpoint])
  @@index([httpStatus])
  @@index([logType])
  @@index([sourceIp])
  @@map("agent_api_request_logs")
}

model AgentDeposit {
  id                   String               @id @default(uuid()) @db.Uuid
  agentId              String               @map("agent_id") @db.Uuid
  paymentReference     String               @unique @map("payment_reference") @db.VarChar(128)
  idempotencyKey       String?              @map("idempotency_key") @db.VarChar(128)
  gateway              PaymentGatewayCode
  amount               Decimal              @db.Decimal(18, 2)
  feeAmount            Decimal              @default(0) @map("fee_amount") @db.Decimal(18, 2)
  netAmount            Decimal              @map("net_amount") @db.Decimal(18, 2)
  status               AgentDepositStatus   @default(INIT)
  gatewayResponse      Json                 @default("{}") @map("gateway_response")
  gatewayTransactionId String?              @map("gateway_transaction_id") @db.VarChar(128)
  ledgerEntryId        String?              @unique @map("ledger_entry_id") @db.Uuid
  expiresAt            DateTime?            @map("expires_at") @db.Timestamptz(6)
  paidAt               DateTime?            @map("paid_at") @db.Timestamptz(6)
  creditedAt           DateTime?            @map("credited_at") @db.Timestamptz(6)
  createdAt            DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt            DateTime?            @map("deleted_at") @db.Timestamptz(6)

  agent       Agent        @relation(fields: [agentId], references: [id], onDelete: Restrict)
  ledgerEntry LedgerEntry? @relation(fields: [ledgerEntryId], references: [id], onDelete: Restrict)

  @@unique([agentId, idempotencyKey])
  @@index([agentId])
  @@index([status])
  @@index([deletedAt])
  @@map("agent_deposits")
}

model AgentManualCredit {
  id               String                    @id @default(uuid()) @db.Uuid
  agentId          String                    @map("agent_id") @db.Uuid
  type             AgentManualCreditType     @default(CREDIT)
  amount           Decimal                   @db.Decimal(18, 2)
  category         AgentManualCreditCategory
  reason           String                    @db.Text
  referenceCode    String?                   @map("reference_code") @db.VarChar(128)
  status           AgentManualCreditStatus   @default(PENDING_APPROVAL)
  ledgerEntryId    String?                   @map("ledger_entry_id") @db.Uuid
  requestedById    String                    @map("requested_by_id") @db.Uuid
  requestedByEmail String                    @map("requested_by_email") @db.VarChar(255)
  requestedRole    UserRole                  @map("requested_role")
  approvedById     String?                   @map("approved_by_id") @db.Uuid
  approvedByEmail  String?                   @map("approved_by_email") @db.VarChar(255)
  rejectedReason   String?                   @map("rejected_reason") @db.Text
  createdAt        DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)
  approvedAt       DateTime?                 @map("approved_at") @db.Timestamptz(6)
  completedAt      DateTime?                 @map("completed_at") @db.Timestamptz(6)
  deletedAt        DateTime?                 @map("deleted_at") @db.Timestamptz(6)

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Restrict)

  @@index([agentId, createdAt])
  @@index([status])
  @@index([deletedAt])
  @@map("agent_manual_credits")
}

model AgentInvite {
  id           String    @id @default(uuid()) @db.Uuid
  tokenHash    String    @unique @map("token_hash") @db.VarChar(255)
  email        String?   @db.VarChar(255)
  createdById  String    @map("created_by_id") @db.Uuid
  usedAt       DateTime? @map("used_at") @db.Timestamptz(6)
  usedByUserId String?   @unique @map("used_by_user_id") @db.Uuid
  expiresAt    DateTime  @map("expires_at") @db.Timestamptz(6)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(6)

  createdBy User  @relation("AgentInviteCreator", fields: [createdById], references: [id], onDelete: Restrict)
  usedBy    User? @relation("AgentInviteUsedBy", fields: [usedByUserId], references: [id], onDelete: SetNull)

  @@index([deletedAt])
  @@map("agent_invites")
}

model AgentKyc {
  id                  String            @id @default(uuid()) @db.Uuid
  agentId             String            @unique @map("agent_id") @db.Uuid
  accountType         AgentAccountType? @map("account_type")
  profile             Json?             @db.JsonB
  documents           Json?             @db.JsonB
  businessProfile     Json?             @map("business_profile") @db.JsonB
  reviewNote          String?           @map("review_note") @db.VarChar(2000)
  requestedFields     Json?             @map("requested_fields") @db.JsonB
  companyName         String            @map("company_name") @db.VarChar(255)
  taxCode             String            @map("tax_code") @db.VarChar(64)

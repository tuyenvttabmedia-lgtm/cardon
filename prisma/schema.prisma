  invoiceMetadata    Json               @default("{}") @map("invoice_metadata")
  customerNote       String?            @map("customer_note") @db.VarChar(512)
  clientTrace        Json               @default("{}") @map("client_trace")
  totalAmount        Decimal            @map("total_amount") @db.Decimal(18, 2)
  faceValue          Decimal            @default(0) @map("face_value") @db.Decimal(18, 2)
  sellAmount         Decimal            @default(0) @map("sell_amount") @db.Decimal(18, 2)
  discountAmount     Decimal            @default(0) @map("discount_amount") @db.Decimal(18, 2)
  paymentMethodCode  String?            @map("payment_method_code") @db.VarChar(64)
  methodDisplayName  String?            @map("method_display_name") @db.VarChar(128)
  paymentGateway     String?            @map("payment_gateway") @db.VarChar(64)
  settlementType     PaymentSettlementType? @map("settlement_type")
  paymentFeePercent  Decimal            @default(0) @map("payment_fee_percent") @db.Decimal(8, 4)
  paymentFeeFixed    Decimal            @default(0) @map("payment_fee_fixed") @db.Decimal(18, 2)
  paymentFeeAmount   Decimal            @default(0) @map("payment_fee_amount") @db.Decimal(18, 2)
  customerPaid       Decimal            @default(0) @map("customer_paid") @db.Decimal(18, 2)
  providerCost       Decimal            @default(0) @map("provider_cost") @db.Decimal(18, 2)
  profit             Decimal            @default(0) @db.Decimal(18, 2)
  paymentStatus      OrderPaymentStatus @default(WAITING_PAYMENT) @map("payment_status")
  fulfillmentStatus  FulfillmentStatus  @default(PENDING) @map("fulfillment_status")
  paymentId          String?            @unique @map("payment_id") @db.Uuid
  paymentExpiresAt   DateTime?          @map("payment_expires_at") @db.Timestamptz(6)
  createdAt          DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt          DateTime?          @map("deleted_at") @db.Timestamptz(6)


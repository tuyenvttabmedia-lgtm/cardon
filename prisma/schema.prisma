  supportTickets       SupportTicket[]
  orderEvents          OrderEvent[]
  cardAccessLogs       CardAccessLog[]

  @@unique([agentId, agentRequestId])
  @@index([orderCode])
  @@index([paymentStatus])
  @@index([fulfillmentStatus])
  @@index([guestEmail])
  @@index([paymentExpiresAt])
  @@index([paymentMethodCode])
  @@index([paymentGateway])
  @@index([settlementType])
  @@index([deletedAt])
  @@map("orders")
}


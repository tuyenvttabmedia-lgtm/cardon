  id               String              @id @default(uuid()) @db.Uuid
  orderId          String              @map("order_id") @db.Uuid
  gateway          PaymentGatewayCode
  methodCode       String?             @map("method_code") @db.VarChar(64)
  settlementType   PaymentSettlementType? @map("settlement_type")
  paymentReference String              @unique @map("payment_reference") @db.VarChar(128)
  idempotencyKey   String?             @unique @map("idempotency_key") @db.VarChar(128)
  amount           Decimal             @db.Decimal(18, 2)
  status           PaymentRecordStatus @default(PENDING)
  gatewayTransactionId String?         @map("gateway_transaction_id") @db.VarChar(128)
  bankTransactionId    String?         @map("bank_transaction_id") @db.VarChar(128)

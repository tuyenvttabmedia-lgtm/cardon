// CardOn.vn — Phase 1A Database Schema
// Source: docs/02_DATABASE_SCHEMA.md + FINAL_ARCHITECTURE_CHECK.md
//
// Phase 1A.2 — Soft delete & audit:
// - deleted_at on business-critical models (never SQL DELETE; see docs/DATA_RETENTION_RULES.md)
// - ledger_entries: append-only — no UPDATE/DELETE; deleted_at must always stay NULL
// - orders: immutable after PAID/SUCCESS fulfillment — amount/product/qty frozen

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


# =============================================================================
# CardOn.vn — Production environment template
# Copy to .env.production and fill ALL values before deploy.
# DO NOT commit .env.production — contains secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Shared infrastructure (postgres / redis)
# -----------------------------------------------------------------------------
POSTGRES_USER=cardon
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
POSTGRES_DB=cardon

# -----------------------------------------------------------------------------
# API service (APP_ROLE=api)
# docker-compose service: api
# -----------------------------------------------------------------------------
APP_PUBLIC_URL=https://cardon.vn
CORS_ORIGINS=https://cardon.vn,https://www.cardon.vn,https://partner.cardon.vn,https://admin.cardon.vn

BUILD_VERSION=6035.2 AGENT REGISTRATION & KYC CENTER
WEB_INTERNAL_URL=http://web:3001
ADMIN_INTERNAL_URL=http://admin:3003
BACKUP_ENABLED=true
BACKUP_DIR=backups

JWT_SECRET=REPLACE_WITH_RANDOM_STRING_MIN_32_CHARS
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
ENCRYPTION_KEY=REPLACE_WITH_RANDOM_ENCRYPTION_KEY_MIN_32_CHARS

WORKER_HEARTBEAT_REQUIRED=true
RUN_MIGRATIONS=true

# MegaPay
# VNPT ePay DepositCode (sandbox demo: VAP001 / WOORIBANK)
MEGAPAY_MERCHANT_ID=your-merchant-id
MEGAPAY_SECRET_KEY=your-3des-hex-key
MEGAPAY_ENDPOINT=https://sandboxva.ecollect.vn:10003/ApiResf_VirtualAccount/services/registerVA
MEGAPAY_BANK_CODE=WOORIBANK
MEGAPAY_RETURN_URL=https://cardon.vn/checkout/result
MEGAPAY_CALLBACK_URL=https://cardon.vn/api/v1/payments/webhook/megapay
MEGAPAY_WEBHOOK_SECRET=depositcode-rsa
# PEM with literal \n escapes (or mount a .pem and leave this empty)
MEGAPAY_NOTIFY_PUBLIC_KEY=

# SePay
SEPAY_API_KEY=your-sepay-api-key
SEPAY_WEBHOOK_SECRET=your-sepay-webhook-secret
SEPAY_BANK_ACCOUNT=0123456789
SEPAY_BANK_CODE=MB
SEPAY_ACCOUNT_NAME=CONG TY CARDON
SEPAY_QR_TEMPLATE=compact

# eSale provider
ESALE_API_URL_CARD=https://partner-esale.example.com/esale/cardshop/
ESALE_API_URL_TOPUP=https://partner-esale.example.com/esale/mobiletopup/
ESALE_AGENCY_CODE=your-agency-code
ESALE_CLIENT_CODE=
ESALE_SECRET_KEY=your-esale-secret
ESALE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
ESALE_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
ESALE_TIMEOUT_MS=30000
PROVIDER_LOW_BALANCE_THRESHOLD=500000
AGENT_LOW_BALANCE_THRESHOLD=100000

# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@cardon.vn
SMTP_PASS=your-smtp-password
SMTP_FROM=noreply@cardon.vn
SMTP_FROM_NAME=CardOn.vn
SMTP_SECURE=false

# Media library (local disk)
MEDIA_UPLOAD_ROOT=uploads
MEDIA_MAX_BYTES=5242880
CMS_MEDIA_GENERATE_WEBP=false
ADMIN_ALERT_EMAIL=ops@cardon.vn

# -----------------------------------------------------------------------------
# Worker service (APP_ROLE=worker)
# docker-compose service: worker
# Inherits all backend vars above via docker-compose anchor.
# No extra vars required — worker uses same DATABASE_URL, REDIS_URL, etc.
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Frontend build-time vars (NEXT_PUBLIC_* baked into static bundle)
# -----------------------------------------------------------------------------

# Customer web (apps/web)
WEB_NEXT_PUBLIC_API_URL=https://cardon.vn/api/v1
WEB_NEXT_PUBLIC_SITE_URL=https://cardon.vn

# Partner portal (apps/partner)
PARTNER_NEXT_PUBLIC_API_URL=https://partner.cardon.vn/api/v1
PARTNER_NEXT_PUBLIC_PARTNER_API_URL=https://partner.cardon.vn/api/partner/v1
PARTNER_NEXT_PUBLIC_SITE_URL=https://partner.cardon.vn
PARTNER_NEXT_PUBLIC_CUSTOMER_SITE_URL=https://cardon.vn

# Admin panel (apps/admin)
ADMIN_NEXT_PUBLIC_API_URL=https://admin.cardon.vn/api/v1
ADMIN_NEXT_PUBLIC_SITE_URL=https://admin.cardon.vn

# =============================================================================
# CardOn.vn — Environment variables
# Copy to .env and adjust for your environment.
# =============================================================================

# Application
APP_ENV=development
APP_ROLE=all
PORT=3000
API_PREFIX=api/v1

# Production-only (required when APP_ENV=production)
# APP_PUBLIC_URL=https://cardon.vn
# CORS_ORIGINS=https://cardon.vn,https://admin.cardon.vn
# WORKER_HEARTBEAT_REQUIRED=true

# PostgreSQL (docker-compose default)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cardon?schema=public

# Redis (docker-compose default)
REDIS_URL=redis://localhost:6379

# Auth (Phase 2B)
JWT_SECRET=change-me-to-a-secure-random-string-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Encryption for sensitive fields (PIN, API secrets) — min 32 characters
ENCRYPTION_KEY=change-me-to-a-secure-encryption-key-32+

# eSale provider (Phase 2F.1) — omit or ESALE_USE_MOCK=true to use mock adapter
# ESALE_USE_MOCK=true
# ESALE_API_URL_CARD=https://partner3sb-esale.zing.vn/esale/cardshop/
# ESALE_API_URL_TOPUP=https://partner3sb-esale.zing.vn/esale/mobiletopup/
# ESALE_AGENCY_CODE=9014780450
# ESALE_CLIENT_CODE=
# ESALE_SECRET_KEY=
# ESALE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# ESALE_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
# ESALE_TIMEOUT_MS=30000
# PROVIDER_LOW_BALANCE_THRESHOLD=500000

# SMTP (required in production)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=noreply@cardon.vn
# SMTP_PASS=
# SMTP_FROM=noreply@cardon.vn
# ADMIN_ALERT_EMAIL=ops@cardon.vn

# Payment gateways (required in production)
# MEGAPAY_MERCHANT_ID=
# MEGAPAY_SECRET_KEY=
# MEGAPAY_ENDPOINT=
# MEGAPAY_WEBHOOK_SECRET=
# SEPAY_API_KEY=
# SEPAY_WEBHOOK_SECRET=
# SEPAY_BANK_ACCOUNT=

# Seed (development only — change before any shared environment)
SEED_SUPER_ADMIN_EMAIL=superadmin@cardon.vn
SEED_SUPER_ADMIN_PASSWORD=ChangeMe123!
